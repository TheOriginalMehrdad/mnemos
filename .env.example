# ─────────────────────────────────────────────────────────────
# ERUDITIO — environment configuration
# Copy to .env and adjust. Every var below is validated at startup.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000

# Database (pgvector-enabled Postgres). Inside docker-compose the host is "postgres".
DATABASE_URL="postgresql://eruditio:eruditio@localhost:5432/eruditio?schema=public"

# Redis (BullMQ). Inside docker-compose the host is "redis".
REDIS_URL="redis://localhost:6379"

# Auth — single user. Credentials are seeded from these values.
JWT_SECRET="change-me-to-a-long-random-secret-minimum-32-characters"
JWT_REFRESH_SECRET="change-me-to-a-different-long-secret-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# Vault — absolute path to the Markdown folder that is watched & indexed.
# Inside docker-compose this is mounted to /vault.
VAULT_PATH="/vault"

# Adaptive queue weights & limits (all read from here, never hardcoded)
NEW_CARDS_PER_SESSION=10
SESSION_CARD_LIMIT=50
OVERDUE_WEIGHT=2.0
MISTAKE_WEIGHT=1.5
NEW_CARD_WEIGHT=0.8
STREAK_BONUS_WEIGHT=0.1
LONG_ABSENCE_THRESHOLD_DAYS=30

# AI provider (stubbed). Set OPENAI_MOCK=false + OPENAI_API_KEY to use a real provider later.
OPENAI_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"
CHAT_MODEL="gpt-4o-mini"
OPENAI_MOCK=true

# CORS (frontend origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:8080"
